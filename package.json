{
  "name": "mitre-mcp",
  "version": "2.0.1",
  "description": "MCP server for MITRE ATT&CK knowledge base - technique lookup, threat intelligence, detection coverage analysis",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mitre-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "typecheck": "tsc --noEmit"
  },
  "author": "Solomon Neas <me@solomonneas.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/solomonneas/mitre-mcp.git"
  },
  "homepage": "https://github.com/solomonneas/mitre-mcp#readme",
  "bugs": {
    "url": "https://github.com/solomonneas/mitre-mcp/issues"
  },
  "keywords": [
    "mcp",
    "mitre",
    "attack",
    "att&ck",
    "soc",
    "security",
    "threat-intelligence",
    "ttp",
    "stix"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "undici": "^7.27.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
